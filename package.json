{
	"name": "tma-studio",
	"version": "1.3.4",
	"description": "A unified solution for developing Telegram Mini Apps.",
	"main": "./out/main/index.js",
	"author": "Erfan Mola",
	"homepage": "https://github.com/erfanmola/tma-studio",
	"scripts": {
		"typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
		"typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
		"typecheck": "npm run typecheck:node && npm run typecheck:web",
		"lint": "biome lint ./src",
		"format": "biome format ./src",
		"start": "electron-vite preview",
		"dev": "electron-vite dev",
		"build": "npm run typecheck && npm run lint && electron-vite build",
		"postinstall": "electron-builder install-app-deps",
		"build:unpack": "npm run build && electron-builder --dir",
		"build:win": "npm run build && electron-builder --win",
		"build:mac": "electron-vite build && electron-builder --mac",
		"build:linux": "electron-vite build && electron-builder --linux"
	},
	"dependencies": {
		"@electron-toolkit/preload": "^3.0.2",
		"@electron-toolkit/utils": "^4.0.0",
		"@electron-uikit/contextmenu": "^1.0.0",
		"@electron-uikit/core": "^1.1.0",
		"@electron-uikit/titlebar": "^1.4.0",
		"@electron-uikit/toast": "^1.0.0",
		"@solidjs/router": "^0.16.1",
		"@tailwindcss/vite": "^4.3.1",
		"@thisbeyond/solid-select": "^0.16.0",
		"animate.css": "^4.1.1",
		"electron-store": "^11.0.2",
		"electron-updater": "^6.8.9",
		"js-crypto-hmac": "^1.0.7",
		"semver": "^7.8.4",
		"solid-icons": "^1.2.0",
		"solid-motionone": "^1.0.4",
		"telegram": "^2.26.22",
		"validator": "^13.15.35"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@electron-toolkit/tsconfig": "^2.0.0",
		"@types/node": "^25.9.3",
		"autoprefixer": "^10.5.0",
		"electron": "^42.4.1",
		"electron-builder": "^26.15.3",
		"electron-vite": "^5.0.0",
		"postcss": "^8.5.15",
		"postcss-loader": "^8.2.1",
		"sass-embedded": "^1.100.0",
		"solid-js": "^1.9.13",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-solid": "^2.11.12"
	}
}
